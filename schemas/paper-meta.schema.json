{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://terrypapers.local/schemas/paper-meta.schema.json",
  "title": "Paper meta.json",
  "description": "Schema for posts/papers/<slug>/meta.json. Validates the source-of-truth metadata shape for paper KG nodes. Predicate vocabulary follows ONTOLOGY.md (CiTO + dcterms + kg).",
  "type": "object",
  "required": ["slug", "post_number", "content_type"],
  "additionalProperties": true,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[0-9]{4}-[a-z0-9-]+$",
      "description": "YYMM-keywords format. e.g. 2505-dexumi"
    },
    "post_id": { "type": "string" },
    "post_number": { "type": "integer", "minimum": 1 },
    "content_type": { "const": "papers" },
    "node_type": {
      "type": "string",
      "enum": ["paper"],
      "description": "Single node type for now. Future: concept, author, method, dataset."
    },
    "status": { "type": "string" },
    "domain": { "type": "string" },
    "subfields": { "type": "array", "items": { "type": "string" } },
    "key_concepts": { "type": "array", "items": { "type": "string" } },
    "methodology": { "type": "array", "items": { "type": "string" } },
    "taxonomy_primary": { "type": "string" },
    "taxonomy_secondary": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_url": { "type": "string", "format": "uri" },
    "source_title": { "type": "string" },
    "source_author": { "type": "string" },
    "source_authors_full": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "affiliation": { "type": "string" }
        }
      }
    },
    "source_date": { "type": "string" },
    "published_at": { "type": "string" },
    "arxiv_id": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{4,5}(v[0-9]+)?$",
      "description": "arXiv ID without 'arXiv:' prefix. Used as canonical bridge to surveys candidate pool — promotes a candidate node to confirmed when set."
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\.[0-9]{4,9}/.+$",
      "description": "DOI without 'doi:' prefix. Secondary canonical bridge."
    },
    "bibtex_key": {
      "type": "string",
      "description": "Optional bibtex key from terry-surveys/bibtex/references.bib for promotion matching when arxiv_id/doi are absent."
    },
    "ai_summary": {
      "type": "object",
      "properties": {
        "one_liner": { "type": "string" },
        "problem": { "type": "string" },
        "solution": { "type": "string" },
        "key_result": { "type": "string" },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "relations": {
      "type": "array",
      "description": "Forward edges only. Inverse edges are auto-generated by export-knowledge.mjs. See ONTOLOGY.md for predicate semantics.",
      "items": {
        "type": "object",
        "required": ["target", "type"],
        "additionalProperties": true,
        "properties": {
          "target": {
            "type": "string",
            "pattern": "^[0-9]{4}-[a-z0-9-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "cites",
              "extends",
              "usesMethodIn",
              "reviews",
              "critiques",
              "sharesGoalWith",
              "sharesTopicWith"
            ],
            "description": "Forward predicate. 7 types from ONTOLOGY.md. cito:* + kg:* (local). Inverse predicates (isExtendedBy etc.) are not allowed in source data."
          },
          "strength": {
            "type": "string",
            "enum": ["foundational", "direct", "tangential"],
            "description": "Optional override; otherwise auto-assigned by predicate type."
          },
          "note": { "type": "string" }
        }
      }
    },
    "figures": { "type": "array" },
    "tables": { "type": "array" },
    "cover_image": { "type": "string" },
    "cover_caption": { "type": "string" },
    "thumb_source": { "type": "string" },
    "thumb_position": { "type": "string" },
    "newsletter_eligible": { "type": "boolean" },
    "featured": { "type": "boolean" },
    "contribution_type": { "type": "string" },
    "google_scholar_url": { "type": "string" },
    "source_project_url": { "type": "string" },
    "source_type": { "type": "string" },
    "reading_time_min": { "type": "number" },
    "citation_status": { "type": "string" },
    "citation_updated_at": { "type": "string" },
    "cover_figure_number": { "type": "integer" },
    "cover_thumb": { "type": "string" },
    "updated_at": { "type": "string" },
    "visibility": { "type": "string" },
    "ai_research_question": { "type": "string" }
  }
}
